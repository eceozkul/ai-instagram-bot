# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Meta Graph API — Instagram yayını için (developers.facebook.com)
META_ACCESS_TOKEN=
IG_BUSINESS_ID=

# Telegram bot — @BotFather'dan al
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Sheets service account — JSON içeriğini tek satırda yapıştır
GOOGLE_SERVICE_ACCOUNT=

# Google Sheet ID — URL'den al
GOOGLE_SHEET_ID=

# GitHub repo (görsel URL'leri için, ör: kullanici/repo-adi)
GITHUB_REPO=

# Dil (tr veya en)
LANGUAGE=tr
